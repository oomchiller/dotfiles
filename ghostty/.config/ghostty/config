font-family = "JetBrainsMono Nerd Font Mono"
font-size = 18
# JetBrainsMono Nerd Font Mono sits a bit low in Ghostty on this setup.
# Lift the baseline slightly so the last row doesn't clip against the bottom edge.
adjust-font-baseline = 2

theme = Snazzy

background-blur = true
background-opacity = 0.85
background-opacity-cells = true

command = /bin/zsh
working-directory = inherit

macos-option-as-alt = true
mouse-hide-while-typing = true

window-padding-x = 8
window-padding-y = 8
window-width = 120
window-height = 32

macos-titlebar-style = hidden

scrollback-limit = 200000
confirm-close-surface = true
cursor-style = block

keybind = super+w=close_tab:this
keybind = super+c=copy_to_clipboard:mixed
keybind = super+v=paste_from_clipboard

# send the tmux prefix directly instead of layering a Ghostty leader.
keybind = super+a=text:\x02
keybind = f18=text:\x02
